{
	"name": "@ymys/directus-extension-fcm-hook",
	"description": "FCM Push Notifications Hook for Directus",
	"icon": "notifications",
	"version": "2.2.5",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-hook",
		"fcm",
		"notifications",
		"firebase"
	],
	"author": "Yusuf M <ymys@users.noreply.github.com>",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist",
		"package.json"
	],
	"directus:extension": {
		"type": "bundle",
		"path": {
			"app": "dist/app.js",
			"api": "dist/index.js"
		},
		"entries": [
			{
				"type": "hook",
				"name": "fcm-hook",
				"source": "src/hook.js"
			},
			{
				"type": "endpoint",
				"name": "fcm-endpoint",
				"source": "src/endpoint.js"
			}
		],
		"host": "^11.0.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "^12.0.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
